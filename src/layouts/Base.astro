---
interface Props {
  title?: string;
  albumHeader?: { title: string; backHref: string; count: number };
}
const { title = 'imgs.wtf', albumHeader } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <header class="nav">
      <div class="nav-inner">
        <div class="nav-left">
          {albumHeader ? (
            <Fragment>
              <a href={albumHeader.backHref} class="back-arrow" aria-label="Back">←</a>
              <span class="brand">{albumHeader.title}</span>
            </Fragment>
          ) : (
            <a href="/" class="brand">simon lürwer</a>
          )}
        </div>
        <div class="nav-center">
          {albumHeader && <span class="count">{albumHeader.count} images</span>}
        </div>
        <div class="nav-right">
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme"></button>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
      (() => {
        const setTheme = (t) => {
          document.documentElement.dataset.theme = t;
          localStorage.setItem('theme', t);
        };
        const btn = document.getElementById('theme-toggle');
        btn?.addEventListener('click', () => {
          setTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
        });
        document.addEventListener('keydown', (e) => {
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          const tag = (e.target && e.target.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || e.target?.isContentEditable) return;
          if (e.key === 'd' || e.key === 'D') setTheme('dark');
          if (e.key === 'l' || e.key === 'L') setTheme('light');
        });
      })();
    </script>
    <style is:global>
      :root,
      :root[data-theme='light'] {
        --bg: #ffffff;
        --fg: #111111;
        --muted: #666666;
        --card-bg: #e6e6e6;
        --nav-bg: rgba(255, 255, 255, 0.85);
        --lightbox-bg: rgba(255, 255, 255, 0.96);
        --btn-bg: rgba(0, 0, 0, 0.06);
        --btn-bg-hover: rgba(0, 0, 0, 0.12);
        --img-hover: 0.85;
      }
      :root[data-theme='dark'] {
        --bg: #0c0c0f;
        --fg: #eaeaea;
        --muted: #8a8a90;
        --card-bg: #17171b;
        --nav-bg: rgba(12, 12, 15, 0.85);
        --lightbox-bg: rgba(12, 12, 15, 0.96);
        --btn-bg: rgba(255, 255, 255, 0.08);
        --btn-bg-hover: rgba(255, 255, 255, 0.16);
        --img-hover: 1.18;
      }
      * {
        box-sizing: border-box;
      }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Helvetica Neue', Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        transition: background 200ms ease, color 200ms ease;
      }
      @keyframes drop-in {
        0% {
          opacity: 0;
          transform: scale(1.14);
          filter: blur(3px);
        }
        70% {
          filter: blur(0);
        }
        100% {
          opacity: 1;
          transform: scale(1);
          filter: blur(0);
        }
      }
      .drop-in {
        animation: drop-in 1200ms cubic-bezier(0.22, 1, 0.36, 1) both;
        transform-origin: center center;
        will-change: transform, opacity, filter;
      }
      @media (prefers-reduced-motion: reduce) {
        .drop-in { animation: none; }
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      .nav {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--nav-bg);
        backdrop-filter: saturate(1.2) blur(10px);
      }
      .nav-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px 24px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 16px;
      }
      .nav-left {
        position: relative;
        display: flex;
        align-items: center;
        min-width: 0;
      }
      .nav-center {
        justify-self: center;
        color: var(--muted);
        font-size: 14px;
      }
      .nav-right {
        justify-self: end;
      }
      .brand {
        font-weight: 600;
        letter-spacing: -0.01em;
        font-size: 15px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .back-arrow {
        position: absolute;
        right: calc(100% + 20px);
        top: 50%;
        transform: translateY(-50%);
        color: var(--fg);
        font-size: 18px;
        line-height: 1;
        font-weight: 400;
        transition: opacity 150ms ease;
      }
      .back-arrow:hover {
        opacity: 0.6;
      }
      .theme-toggle {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        border: none;
        padding: 0;
        background: var(--fg);
        cursor: pointer;
        transition: background 200ms ease, transform 200ms ease;
      }
      .theme-toggle:hover {
        transform: scale(1.08);
      }
      main {
        padding: 0 24px 80px;
        max-width: 1400px;
        margin: 0 auto;
      }
      @media (max-width: 640px) {
        .nav-inner { padding: 16px; }
        main { padding: 0 16px 48px; }
        .nav-left { gap: 12px; }
        .back-arrow {
          position: static;
          transform: none;
        }
      }
    </style>
  </body>
</html>
