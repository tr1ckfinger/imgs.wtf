---
interface Props {
  title?: string;
  albumHeader?: { title: string; backHref: string; count: number };
}
const { title = 'imgs.wtf', albumHeader } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = path === '/';
const isAbout = path === '/about';
const isContact = path === '/contact';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- The "-v2" suffix is a cache-bust: iOS Safari's OS-level favicon
         database (shared with Spotlight / Siri suggestions) hung onto
         an Astro-starter icon from an earlier deploy and refused to
         re-fetch from the same URL even after Website Data was cleared.
         Renaming the files forces a fresh fetch. -->
    <link rel="icon" type="image/svg+xml" href="/favicon-v2.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32-v2.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-v2.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <!-- Populated by the inline script below (and updated on toggle) so
         the Safari top bar / Android task-switcher chrome tint matches
         the active theme. Values mirror the --bg custom properties. -->
    <meta name="theme-color" id="theme-color-meta" content="#ffffff" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
        const meta = document.getElementById('theme-color-meta');
        if (meta) meta.setAttribute('content', theme === 'dark' ? '#0c0c0f' : '#ffffff');
      })();
    </script>
  </head>
  <body>
    <header class="nav">
      <div class="nav-inner">
        <div class="nav-left">
          {albumHeader ? (
            <Fragment>
              <a href={albumHeader.backHref} class="back-arrow" aria-label="Back">←</a>
              <span class="brand">{albumHeader.title}</span>
            </Fragment>
          ) : (
            <a href="/" class="brand">simon lürwer</a>
          )}
        </div>
        <div class="nav-center">
          {albumHeader && <span class="count">{albumHeader.count} images</span>}
        </div>
        <div class="nav-right">
          <nav class="nav-links" aria-label="Primary">
            <a href="/" data-label="imgs" class:list={['nav-link', { active: isHome }]}>imgs</a>
            <a href="/about" data-label="abt me" class:list={['nav-link', { active: isAbout }]}>abt me</a>
            <a href="/contact" data-label="cntct me" class:list={['nav-link', { active: isContact }]}>cntct me</a>
          </nav>
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme"></button>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
      (() => {
        const themeColorMeta = document.getElementById('theme-color-meta');
        const setTheme = (t) => {
          document.documentElement.dataset.theme = t;
          localStorage.setItem('theme', t);
          // Keep Safari's top bar / Android's task-switcher tint in sync
          // with the page background when the user toggles themes.
          if (themeColorMeta) {
            themeColorMeta.setAttribute('content', t === 'dark' ? '#0c0c0f' : '#ffffff');
          }
        };
        const btn = document.getElementById('theme-toggle');
        btn?.addEventListener('click', () => {
          setTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
        });
        document.addEventListener('keydown', (e) => {
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          const tag = (e.target && e.target.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || e.target?.isContentEditable) return;
          if (e.key === 'd' || e.key === 'D') setTheme('dark');
          if (e.key === 'l' || e.key === 'L') setTheme('light');
        });

        const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
        const playFade = (img) => {
          img.classList.add('loaded');
          if (reduceMotion || typeof img.animate !== 'function') return;
          // The z-travel is on the tile now; per-image fade is pure
          // opacity. WAAPI is still used (instead of a CSS transition)
          // because Safari iOS skips transition interpolation on an
          // <img> that hasn't painted a prior state.
          img.animate(
            [{ opacity: 0 }, { opacity: 1 }],
            // 'backwards' keeps the start keyframe applied before play,
            // and releases the animated value after play so :hover
            // filter transitions on the image aren't pinned by WAAPI.
            { duration: 1000, easing: 'ease-out', fill: 'backwards' }
          );
        };
        const whenDecoded = (img, cb) => {
          if (typeof img.decode === 'function') img.decode().then(cb, cb);
          else cb();
        };
        const readyFor = (img) => new Promise((resolve) => {
          if (img.complete && img.naturalWidth > 0) {
            whenDecoded(img, resolve);
          } else {
            img.addEventListener('load', () => whenDecoded(img, resolve), { once: true });
            img.addEventListener('error', () => resolve(), { once: true });
          }
        });
        // Measure each drop-in tile's 2D distance from the grid center so
        // tiles closer to the center travel less on the z-axis (smaller
        // starting scale) and arrive sooner. Top-left and top-right of a
        // symmetric grid resolve to the same distance, so they animate
        // identically.
        const tiles = Array.from(document.querySelectorAll('.drop-in'));
        if (tiles.length) {
          const rects = tiles.map((t) => t.getBoundingClientRect());
          const cxs = rects.map((r) => r.left + r.width / 2);
          const cys = rects.map((r) => r.top + r.height / 2);
          const gridCx = (Math.min(...cxs) + Math.max(...cxs)) / 2;
          const gridCy = (Math.min(...cys) + Math.max(...cys)) / 2;
          const dists = rects.map((_, i) => Math.hypot(cxs[i] - gridCx, cys[i] - gridCy));
          const maxD = Math.max(...dists) || 1;
          tiles.forEach((tile, i) => {
            const n = dists[i] / maxD; // 0 = center, 1 = furthest corner
            // Scale lives on the tile again, so the range is bounded to
            // what fits in the layout gap — adjacent corner tiles can
            // both push outward at most ~5% each before they'd overlap
            // on the tightest (mobile) breakpoint.
            const scale = 1.03 + n * 0.07; // 1.03 → 1.10
            const delay = n * 240;
            tile.style.setProperty('--drop-scale', scale.toFixed(3));
            tile.style.animationDelay = delay.toFixed(0) + 'ms';
          });
        }
        requestAnimationFrame(() => document.body.classList.add('drop-ready'));

        // Fade each image in the moment it's ready. Syncing across the
        // whole grid doesn't work once loading="lazy" enters the picture —
        // off-screen images never fire a load event until you scroll, so
        // a Promise.all() gate would hang forever.
        const imgs = Array.from(document.querySelectorAll('img.img-fade'));
        imgs.forEach((img) => readyFor(img).then(() => playFade(img)));
      })();
    </script>
    <style is:global>
      :root,
      :root[data-theme='light'] {
        --bg: #ffffff;
        --fg: #111111;
        --muted: #666666;
        --card-bg: #e6e6e6;
        --nav-bg: rgba(255, 255, 255, 0.85);
        --lightbox-bg: rgba(255, 255, 255, 0.96);
        --btn-bg: rgba(0, 0, 0, 0.06);
        --btn-bg-hover: rgba(0, 0, 0, 0.12);
        --img-hover: 0.85;
      }
      :root[data-theme='dark'] {
        --bg: #0c0c0f;
        --fg: #eaeaea;
        --muted: #8a8a90;
        --card-bg: #17171b;
        --nav-bg: rgba(12, 12, 15, 0.85);
        --lightbox-bg: rgba(12, 12, 15, 0.96);
        --btn-bg: rgba(255, 255, 255, 0.08);
        --btn-bg-hover: rgba(255, 255, 255, 0.16);
        --img-hover: 1.18;
      }
      * {
        box-sizing: border-box;
      }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Helvetica Neue', Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        transition: background 200ms ease, color 200ms ease;
      }
      @keyframes drop-in {
        0% {
          opacity: 0;
          transform: scale(var(--drop-scale, 1.08));
          filter: blur(3px);
        }
        70% {
          filter: blur(0);
        }
        100% {
          opacity: 1;
          transform: scale(1);
          filter: blur(0);
        }
      }
      .drop-in {
        animation: drop-in 1200ms cubic-bezier(0.22, 1, 0.36, 1) both;
        animation-play-state: paused;
        transform-origin: center center;
        will-change: transform, opacity, filter;
      }
      body.drop-ready .drop-in {
        animation-play-state: running;
      }
      .img-fade {
        opacity: 0;
        will-change: opacity, filter, transform;
      }
      .img-fade.loaded {
        opacity: 1;
      }
      @media (prefers-reduced-motion: reduce) {
        .drop-in { animation: none; }
        .img-fade { opacity: 1; }
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      .nav {
        position: sticky;
        top: 0;
        z-index: 10;
        background: var(--nav-bg);
        backdrop-filter: saturate(1.2) blur(10px);
      }
      .nav-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px 24px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 16px;
      }
      .nav-left {
        position: relative;
        display: flex;
        align-items: center;
        min-width: 0;
      }
      .nav-center {
        justify-self: center;
        color: var(--muted);
        font-size: 14px;
      }
      .nav-right {
        justify-self: end;
        display: flex;
        align-items: center;
        gap: 22px;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 18px;
        font-size: 14px;
      }
      .nav-link {
        color: var(--muted);
        transition: color 150ms ease;
        letter-spacing: -0.005em;
        white-space: nowrap;
      }
      .nav-link:hover {
        color: var(--fg);
      }
      /* The active link stays at font-weight 400 so its glyph metrics
         (and therefore the link's box width) never change — a bumped
         font-weight would reflow the neighbours even with a reserved-
         width pseudo-element, because the font stack's 500 variant
         advances slightly differently. Instead, a two-axis text-shadow
         of currentColor fakes the added weight visually: the shadow
         adds paint, not layout. */
      .nav-link.active {
        color: var(--fg);
        text-shadow:
          0.3px 0 0 currentColor,
          -0.3px 0 0 currentColor;
      }
      .brand {
        font-weight: 600;
        letter-spacing: -0.01em;
        font-size: 15px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .back-arrow {
        position: absolute;
        right: calc(100% + 20px);
        top: 50%;
        transform: translateY(-50%);
        color: var(--fg);
        font-size: 18px;
        line-height: 1;
        font-weight: 400;
        transition: opacity 150ms ease;
      }
      .back-arrow:hover {
        opacity: 0.6;
      }
      .theme-toggle {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        border: none;
        padding: 0;
        background: var(--fg);
        cursor: pointer;
        transition: background 200ms ease, transform 200ms ease;
      }
      .theme-toggle:hover {
        transform: scale(1.08);
      }
      main {
        padding: 0 24px 80px;
        max-width: 1400px;
        margin: 0 auto;
      }
      @media (max-width: 640px) {
        /* Let the right column size to its content so the links and
           toggle always sit flush against the right edge; the brand
           gets whatever space is left and truncates with an ellipsis
           if the viewport is too narrow. The 1fr ensures there's
           always a gap between the brand and the first nav link. */
        .nav-inner {
          padding: 16px;
          gap: 12px;
          grid-template-columns: minmax(0, 1fr) auto auto;
        }
        main { padding: 0 16px 48px; }
        .nav-left { gap: 12px; }
        .back-arrow {
          position: static;
          transform: none;
        }
        .nav-right { gap: 14px; }
        .nav-links { gap: 12px; font-size: 13px; }
        /* Album count hides on narrow screens so the nav links and
           album title both have room to breathe. */
        .nav-center { display: none; }
        .brand { font-size: 14px; }
      }
    </style>
  </body>
</html>
