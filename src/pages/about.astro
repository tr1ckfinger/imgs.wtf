---
import Base from '../layouts/Base.astro';
---

<Base title="abt me — imgs.wtf">
  <section class="page">
    <h1>abt me</h1>
    <div class="body">
      <p>[Placeholder — a line or two introducing who you are and what you do.]</p>
      <p>[Placeholder — what you shoot, what draws you to it, where you're based.]</p>
      <p>[Placeholder — a closing note: process, gear, ongoing projects, anything worth mentioning.]</p>
    </div>
  </section>
</Base>

<style>
  .page {
    max-width: 640px;
    padding: 48px 0 80px;
  }
  .page h1 {
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--fg);
  }
  .body p {
    color: var(--fg);
    line-height: 1.65;
    font-size: 16px;
    margin: 0 0 18px;
  }
  .body p:last-child {
    margin-bottom: 0;
  }
  @media (max-width: 640px) {
    .page { padding: 24px 0 56px; }
    .page h1 { font-size: 26px; margin-bottom: 20px; }
    .body p { font-size: 15px; }
  }
</style>
