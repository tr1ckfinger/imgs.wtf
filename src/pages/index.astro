---
import Base from '../layouts/Base.astro';
import { getAlbums, cldUrl } from '../lib/cloudinary';

const albums = await getAlbums();
---

<Base title="imgs.wtf">
  <section class="grid">
    {albums.map((album) => (
      <a href={`/${album.slug}`} class="card">
        <img
          src={cldUrl(album.cover.public_id, { w: 1200, h: 1500, crop: 'fill' })}
          alt={album.title}
          loading="lazy"
        />
        <span class="title">{album.title}</span>
      </a>
    ))}
  </section>

  {albums.length === 0 && (
    <p class="empty">No albums yet. Upload images to folders in Cloudinary.</p>
  )}
</Base>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding-top: 8px;
  }
  @media (max-width: 1024px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; gap: 12px; }
  }
  .card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    background: #f2f2f2;
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .card:hover img {
    transform: scale(1.02);
  }
  .title {
    position: absolute;
    left: 20px;
    bottom: 18px;
    color: #fff;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }
  .empty {
    color: var(--muted);
    padding: 80px 0;
    text-align: center;
  }
</style>
