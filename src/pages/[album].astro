---
import Base from '../layouts/Base.astro';
import Lightbox from '../components/Lightbox.astro';
import { getAlbums, cldUrl } from '../lib/cloudinary';

export async function getStaticPaths() {
  const albums = await getAlbums();
  return albums.map((album) => ({
    params: { album: album.slug },
    props: { album },
  }));
}

const { album } = Astro.props;
---

<Base
  title={`${album.title} — imgs.wtf`}
  albumHeader={{ title: album.title, backHref: '/', count: album.images.length }}
>
  <section class="justified">
    {album.images.map((img) => {
      const aspect = img.width / img.height;
      return (
        <figure
          class="drop-in"
          style={`--aspect: ${aspect}; flex-grow: ${aspect}; flex-basis: calc(${aspect} * var(--row-h)); aspect-ratio: ${aspect};`}
        >
          <img
            class="thumb img-fade"
            src={cldUrl(img.public_id, { w: 1400 })}
            data-full={cldUrl(img.public_id, { w: 3200, q: 'auto:best' })}
            data-zoom={cldUrl(img.public_id, { q: 'auto:best' })}
            alt=""
            loading="lazy"
            width={img.width}
            height={img.height}
          />
        </figure>
      );
    })}
    <i class="filler"></i>
    <i class="filler"></i>
    <i class="filler"></i>
    <i class="filler"></i>
  </section>

  <Lightbox />
</Base>

<style>
  .justified {
    padding-top: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 38px;
    --row-h: 320px;
  }
  @media (max-width: 900px) { .justified { --row-h: 240px; gap: 18px; } }
  @media (max-width: 500px) { .justified { --row-h: 180px; gap: 10px; } }
  .justified figure {
    margin: 0;
    overflow: hidden;
    border-radius: 3px;
    background: var(--card-bg);
    min-width: 0;
  }
  .justified figure img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    cursor: pointer;
    transition: filter 380ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .justified figure img:hover {
    filter: brightness(var(--img-hover));
  }
  /* Phantom fillers so the last row keeps natural sizing instead of stretching. */
  .justified .filler {
    flex-grow: 1000000000;
    flex-basis: 0;
    content: '';
    height: 0;
  }
</style>
