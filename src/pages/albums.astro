---
import Base from '../layouts/Base.astro';
import { getAlbums, cldUrl, albumHref } from '../lib/cloudinary';

const all = await getAlbums();
const albums = all.filter((a) => a.category === 'album');

// Pick the freshest album's cover as the OG image so link previews
// show recent work instead of a stale shot.
const ogImage =
  albums.length > 0
    ? cldUrl(albums[0].cover.public_id, {
        w: 1200,
        h: 630,
        crop: 'fill',
        q: 'auto:best',
      })
    : undefined;

const description =
  'Photo albums by Simon Lürwer — personal photography series shot in Hamburg, Germany and abroad.';
---

<Base
  title="Albums — Simon Lürwer Photography"
  description={description}
  ogImage={ogImage}
>
  <section class="grid">
    {albums.map((album) => (
      <a
        href={albumHref(album)}
        class="card drop-in"
      >
        <img
          class="img-fade"
          src={cldUrl(album.cover.public_id, { w: 1200, h: 1500, crop: 'fill' })}
          alt={album.title}
          loading="lazy"
        />
        <span class="title">{album.title}</span>
      </a>
    ))}
  </section>

  {albums.length === 0 && (
    <p class="empty">No albums yet. Upload images to subfolders of Albums/ in Cloudinary.</p>
  )}
</Base>

<style>
  /* Album listing — same 4-up tile grid the home page used to be,
     kept here as an alternate way in for visitors who prefer to
     browse by series rather than scroll the flat all-photos feed. */
  /* Gaps mirror the home grid (.justified in index.astro) so the two
     ways into the photos feel like they share a rhythm — switching
     between /imgs and /albms doesn't read as "different design". */
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    padding-top: 8px;
  }
  @media (max-width: 1200px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 900px) {
    .grid { gap: 10px; }
  }
  @media (max-width: 760px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .grid { gap: 6px; }
  }
  .card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    background: var(--card-bg);
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 380ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .card:hover img {
    filter: brightness(var(--img-hover));
  }
  .title {
    /* Title sits over the bottom-left corner of the cover, with a
       soft shadow so it reads against either light or dark covers
       without needing a gradient overlay. */
    position: absolute;
    left: 14px;
    bottom: 12px;
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }
  .empty {
    color: var(--muted);
    padding: 80px 0;
    text-align: center;
  }
</style>
