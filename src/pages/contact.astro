---
import Base from '../layouts/Base.astro';
---

<Base title="cntct — imgs.wtf">
  <section class="page">
    <h1>cntct</h1>
    <div class="body">
      <p>[Placeholder — a line or two introducing who you are and what you do.]</p>
      <p>[Placeholder — what you shoot, what draws you to it, where you're based.]</p>
      <p>[Placeholder — a closing note: process, gear, ongoing projects, anything worth mentioning.]</p>
      <dl class="fields">
        <dt>email</dt>
        <dd><a href="mailto:hello@example.com">hello@example.com</a></dd>
        <dt>instagram</dt>
        <dd><a href="https://instagram.com/username" target="_blank" rel="noreferrer">@username</a></dd>
        <dt>based in</dt>
        <dd>[city, country]</dd>
      </dl>
    </div>
  </section>
</Base>

<style>
  .page {
    max-width: 640px;
    /* <main> is full-width now (no centering of its own) so the
       prose centers itself here. */
    margin: 0 auto;
    padding: 48px 0 80px;
  }
  .page h1 {
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--fg);
  }
  .body p {
    color: var(--fg);
    line-height: 1.65;
    font-size: 16px;
    margin: 0 0 18px;
  }
  /* Extra space between the prose and the fields list — the prose
     introduces, the fields are the actionable bit. */
  .body p:last-of-type {
    margin-bottom: 32px;
  }
  .fields {
    display: grid;
    grid-template-columns: max-content 1fr;
    row-gap: 12px;
    column-gap: 28px;
    margin: 0;
  }
  .fields dt {
    color: var(--muted);
    font-size: 14px;
    align-self: center;
  }
  .fields dd {
    margin: 0;
    font-size: 15px;
    color: var(--fg);
  }
  .fields a {
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: opacity 150ms ease;
  }
  .fields a:hover {
    opacity: 0.6;
  }
  @media (max-width: 640px) {
    .page { padding: 24px 0 56px; }
    .page h1 { font-size: 26px; margin-bottom: 20px; }
    .body p { font-size: 15px; }
    .body p:last-of-type { margin-bottom: 24px; }
    .fields { column-gap: 20px; row-gap: 10px; }
    .fields dt { font-size: 13px; }
    .fields dd { font-size: 14px; }
  }
</style>
