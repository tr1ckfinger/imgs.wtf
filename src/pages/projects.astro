---
import Base from '../layouts/Base.astro';
import { getAlbums, cldUrl, albumHref } from '../lib/cloudinary';

const all = await getAlbums();
const projects = all.filter((a) => a.category === 'project');
---

<Base title="prjcts — imgs.wtf">
  <section class="grid">
    {projects.map((project) => (
      <a
        href={albumHref(project)}
        class="card drop-in"
      >
        <img
          class="img-fade"
          src={cldUrl(project.cover.public_id, { w: 1200, h: 1500, crop: 'fill' })}
          alt={project.title}
          loading="lazy"
        />
        <span class="title">{project.title}</span>
      </a>
    ))}
  </section>

  {projects.length === 0 && (
    <p class="empty">No projects yet. Upload images to subfolders of Projects/ in Cloudinary.</p>
  )}
</Base>

<style>
  /* Projects listing — same 4-up tile grid as the albums listing, kept
     identical so the two ways in (series vs themed/commissioned work)
     share one visual rhythm. Gaps mirror the home grid (.justified in
     index.astro). */
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    padding-top: 8px;
  }
  @media (max-width: 1200px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 900px) {
    .grid { gap: 10px; }
  }
  @media (max-width: 760px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .grid { gap: 6px; }
  }
  .card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    background: var(--card-bg);
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 380ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .card:hover img {
    filter: brightness(var(--img-hover));
  }
  .title {
    /* Title sits over the bottom-left corner of the cover, with a
       soft shadow so it reads against either light or dark covers
       without needing a gradient overlay. */
    position: absolute;
    left: 14px;
    bottom: 12px;
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }
  .empty {
    color: var(--muted);
    padding: 80px 0;
    text-align: center;
  }
</style>
